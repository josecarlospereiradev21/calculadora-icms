@page
@using System.Globalization
@model CalcularModel
@{
    Layout = "_Layout";
}

<link rel="stylesheet" href="~/css/calcular.css" />

<div class="container">

    <a href="/">
        <img src="/img/1533063204.svg" alt="Voltar" class="img-voltar" />
    </a>

    <h1 class="display-5 text-center">Calcular ICMS de Pneus</h1>

    <form method="post">

        <div class="mb-3">
            <label>Insira quantos modelos são?</label>

            <div class="d-flex gap-2">
                <input type="number" id="qtdModelos" name="qtdModelos" min="1" class="form-control" />
                <button type="button" onclick="gerarCampos()" class="btn btn-primary">Gerar</button>
            </div>
        </div>

        <hr />

        <div id="areaPneus"></div>

        <br />
        <button type="submit" class="btn btn-success w-100">Calcular</button>

    </form>

</div>

@if (Model.MostrarResultado)
{
    var cultura = new CultureInfo("pt-BR");

    var baseCalc = Model.BaseCalculo.ToString("C2", cultura);
    var valorIcms = Model.ValorIcms.ToString("C2", cultura);

    <div class="resultado-box">
        <p class="resultado-texto">
            BASE DE CALCULO ICMS ST: <strong>@baseCalc</strong> 
            / VALOR DE ICMS ST: <strong>@valorIcms</strong>
        </p>

        <button type="button" class="botao-copiar" onclick="copiarResultado()">Copiar</button>
    </div>

    <script>
        function copiarResultado() {
            const base = "@baseCalc";
            const valor = "@valorIcms";

            const texto =
                "BASE DE CALCULO ICMS ST: " + base +
                " / VALOR DE ICMS ST: " + valor;

            navigator.clipboard.writeText(texto);

            const botao = document.querySelector(".botao-copiar");
            botao.innerText = "Copiado!";

            setTimeout(() => {
                botao.innerText = "Copiar";
            }, 1500);
        }
    </script>
}

<script>
function gerarCampos() {

    const qtd = document.getElementById("qtdModelos").value;
    const area = document.getElementById("areaPneus");

    area.innerHTML = "";

    for (let i = 0; i < qtd; i++) {

        area.innerHTML += `
        <div class="card p-3 mb-3">

            <h5>Modelo ${i + 1}</h5>

            <div class="row">

                <div class="col-md-6 mb-2">
                    <label>Preço</label>
                    <input type="number" step="0.01" name="Pneus[${i}].Preco" class="form-control" required />
                </div>

                <div class="col-md-6 mb-2">
                    <label>Quantidade</label>
                    <input type="number" name="Pneus[${i}].Quantidade" class="form-control" required />
                </div>

            </div>

        </div>
        `;
    }
}
</script>